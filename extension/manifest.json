{
  "manifest_version": 3,
  "name": "GATE 2027 Prep Tracker",
  "version": "1.0.0",
  "description": "Track your GATE 2027 preparation — countdown, focus time, and todos.",
  "permissions": ["storage", "alarms", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GATE 2027 Prep Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ]
}
