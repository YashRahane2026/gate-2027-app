DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/gate_prep?sslmode=require"
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional - comment out if not using)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Pusher (real-time Study Group)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap2"

# Public Pusher key (exposed to client)
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
